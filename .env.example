# SQLite databazovy soubor (pro produkci muzes prepnout na Postgres - viz README)
DATABASE_URL="file:./dev.db"

# Vygeneruj nahodny string, napr.: openssl rand -base64 32
NEXTAUTH_SECRET="zmen-me-na-nahodny-tajny-string"

# Adresa, na ktere appka bezi (POZOR: musi byt spravne i v produkci na https://tvoje-domena.cz,
# pouziva se i pro odkazy v emailech)
NEXTAUTH_URL="http://localhost:3000"

# --- SMTP (odesilani emailu: potvrzeni registrace, notifikace adminum) ---
# Pokud tyto promenne nevyplnis, appka funguje dal, jen se emaily neodesilaji
# (jen se zaloguji do konzole serveru). Priklady nastaveni najdes v README.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ultimate Streamer Challenge <noreply@tvoje-domena.cz>"

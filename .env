# --- DATABASE (PostgreSQL) ---
# Pro Vercel doporuceno: Neon (neon.tech) nebo Supabase - oba maji zdarma tier
# a oba davaji DVA connection stringy - pooled (pro appku) a direct (pro migrace).
#
# Neon: v dashboardu zvol "Pooled connection" pro DATABASE_URL
#       a "Direct connection" pro DIRECT_URL.
# Supabase: Settings -> Database -> "Connection pooling" (port 6543) pro DATABASE_URL,
#       "Connection string" (port 5432) pro DIRECT_URL.
DATABASE_URL="postgresql://neondb_owner:npg_BZ1uVkaLf2Dz@ep-wild-pond-as64jpbp-pooler.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:npg_BZ1uVkaLf2Dz@ep-wild-pond-as64jpbp.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Vygeneruj nahodny string, napr.: openssl rand -base64 32
NEXTAUTH_SECRET="zmen-me-na-nahodny-tajny-string"

# Lokalne: http://localhost:3000
# Na Vercelu: https://tvuj-projekt.vercel.app (nebo vlastni domena)
